generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/**
 * =========================
 * ENUMS
 * =========================
 */

enum UserRole {
  BUYER
  OPS
  FINANCE
  ADMIN
}

enum OrderStatus {
  CREATED
  PENDING_APPROVAL
  ACCEPTED
  REJECTED
  IN_PROGRESS
  COMPLETED
}

enum BatchStatus {
  CREATED
  INVOICED
  PAYMENT_APPROVED
  IN_PROGRESS
  PAID
  COMPLETED
}

enum PaymentTerm {
  NET_15
  NET_30
  NET_60
  NET_90
}

enum PaymentMode {
  NET_TERMS
  ADVANCE_BALANCE
  PAY_BEFORE_DISPATCH
  STANDARD
}

/**
 * =========================
 * CORE
 * =========================
 */

model Organization {
  id                  String       @id @default(uuid())
  name                String
  gst                 String?
  state               String
  buyerMargin         Float?       // Buyer-level margin data placeholder
  defaultPaymentTerm       PaymentTerm?  // Default Net 15/30/60/90 for this buyer
  defaultPaymentMode       PaymentMode?  @default(NET_TERMS)
  advancePercent           Float?        // For ADVANCE_BALANCE e.g. 20
  earlyPayDiscountPercent  Float?
  earlyPayDiscountDays     Int?
  retentionPercent         Float?
  retentionDays            Int?
  securityDepositAmount    Float?
  creditLimit              Float?
  blockNewOrdersIfOverdue  Boolean      @default(false)
  createdAt                DateTime      @default(now())

  users    User[]
  orders   Order[]
  contracts Contract[]
  invoices Invoice[]
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole
  orgId        String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  org Organization? @relation(fields: [orgId], references: [id])

  ordersCreated    Order[]            @relation("OrderCreatedBy")
  batchesCreated   OrderBatch[]       @relation("BatchCreatedBy")
  inventoryUpdates Inventory[]        @relation("InventoryUpdatedBy")
  inventoryLogs    InventoryHistory[] @relation("InventoryRecordedBy")
  sessions         Session[]
}

/**
 * =========================
 * PRODUCT & SITE
 * =========================
 */

model Product {
  id       String  @id @default(uuid())
  sku      String  @unique
  name     String
  type     String
  grade    String
  cvMin    Int
  cvMax    Int
  ashPct   Float
  moisture Float
  pricePMT Float
  active   Boolean @default(true)

  inventories      Inventory[]
  inventoryHistory InventoryHistory[]
  batches          OrderBatch[]
  requestedOrders  Order[] @relation("OrderRequestedProduct")
  contracts        Contract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Site {
  id     String  @id @default(uuid())
  name   String
  city   String
  state  String
  active Boolean @default(true)

  inventories      Inventory[]
  inventoryHistory InventoryHistory[]
  batches          OrderBatch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * =========================
 * INVENTORY (LOCKED)
 * =========================
 */

model Inventory {
  id          String   @id @default(uuid())
  productId   String
  siteId      String
  availableMT Float
  updatedAt   DateTime @updatedAt
  updatedBy   String

  product Product @relation(fields: [productId], references: [id])
  site    Site    @relation(fields: [siteId], references: [id])
  updater User    @relation("InventoryUpdatedBy", fields: [updatedBy], references: [id])

  @@unique([productId, siteId])
}

model InventoryHistory {
  id         String   @id @default(uuid())
  productId  String
  siteId     String
  quantity   Float
  recordedAt DateTime @default(now())
  recordedBy String

  product  Product @relation(fields: [productId], references: [id])
  site     Site    @relation(fields: [siteId], references: [id])
  recorder User    @relation("InventoryRecordedBy", fields: [recordedBy], references: [id])
}

/**
 * =========================
 * ORDER & EXECUTION
 * =========================
 */

model Order {
  id                 String      @id @default(uuid())
  orgId              String
  status             OrderStatus @default(CREATED)
  requestedQuantityMT Float?      // Original order quantity requested by buyer
  requestedProductId String?     // Product requested by buyer (before batches are created)
  deliveryLocation   String?      // Buyer-provided delivery location (city/site/address label)
  orderSource        String       @default("WEB") // For BI attribution (WEB/ERP/ADMIN/etc.)
  notes              String?      // Optional buyer notes for Ops/Finance context
  rejectionReason    String?      // Reason for rejection (if rejected by Ops)
  createdAt          DateTime    @default(now())
  createdBy          String

  org     Organization @relation(fields: [orgId], references: [id])
  creator User         @relation("OrderCreatedBy", fields: [createdBy], references: [id])
  requestedProduct Product? @relation("OrderRequestedProduct", fields: [requestedProductId], references: [id])
  batches OrderBatch[]
}

model OrderBatch {
  id              String      @id @default(uuid())
  orderId         String
  productId       String
  siteId          String
  quantityMT      Float
  committedMT     Float?      // Committed volume (manual reporting)
  suppliedMT      Float?      // Supplied volume (manual reporting)
  dispatchImageUrl String?    // Image uploaded when Ops dispatches material
  status          BatchStatus @default(CREATED)
  deliveryAt      DateTime?
  leftFromSiteAt  DateTime?   // When batch left the factory site
  dispatchedAt    DateTime?   // When material was dispatched for delivery
  freightCost         Float?     // Manual freight cost for this batch (entered at/after dispatch)
  freightCurrency     String?    @default("INR")
  freightVendorName   String?
  freightInvoiceRef   String?
  freightNotes        String?
  freightEnteredAt    DateTime?
  freightEnteredBy    String?
  batchMargin     Float?      // Batch-level margin data placeholder
  eWayBillNumber  String?     // E-way bill number (optional, for GST compliance)
  eWayBillDate    DateTime?   // E-way bill date
  createdAt       DateTime    @default(now())
  createdBy       String

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  site    Site    @relation(fields: [siteId], references: [id])
  creator User    @relation("BatchCreatedBy", fields: [createdBy], references: [id])

  invoices Invoice[]
}

/**
 * =========================
 * FINANCE
 * =========================
 */

model Invoice {
  id                       String       @id @default(uuid())
  batchId                  String?      // Null for SECURITY_DEPOSIT
  orgId                    String?      // For SECURITY_DEPOSIT
  number                   String
  subtotal                 Float
  gstType                  String
  gstRate                  Float
  gstAmount                Float
  cgst                     Float?
  sgst                     Float?
  igst                     Float?
  totalAmount              Float
  paymentTerm              PaymentTerm
  status                   String
  erpStatus                String       @default("PENDING")
  syncedToERP              Boolean      @default(false)
  irn                      String?
  irnDate                  DateTime?
  invoiceType              String       @default("STANDARD") // STANDARD | ADVANCE | BALANCE | SECURITY_DEPOSIT
  parentInvoiceId          String?
  advancePercent           Float?
  dueDateOverride          DateTime?
  earlyPayDiscountPercent  Float?
  earlyPayDiscountDays     Int?
  retentionPercent         Float?
  retentionDueDate         DateTime?
  createdAt                DateTime     @default(now())

  batch          OrderBatch?   @relation(fields: [batchId], references: [id])
  org            Organization? @relation(fields: [orgId], references: [id])
  parentInvoice  Invoice?      @relation("AdvanceBalance", fields: [parentInvoiceId], references: [id])
  balanceInvoices Invoice[]    @relation("AdvanceBalance")
  payments       Payment[]
  creditNotes    CreditNote[]
}

model Payment {
  id         String    @id @default(uuid())
  invoiceId  String
  amount     Float
  mode       String
  proofUrl   String?
  verified   Boolean   @default(false)
  verifiedAt DateTime? // When finance verified (for SLA)
  createdAt  DateTime  @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model CreditNote {
  id        String   @id @default(uuid())
  invoiceId String
  number    String   // e.g. CN-202503-001
  amount    Float
  reason    String?  // Return, cancellation, adjustment
  status    String   // DRAFT, ISSUED, CANCELLED
  createdAt DateTime @default(now())
  createdBy String?

  invoice  Invoice  @relation(fields: [invoiceId], references: [id])
  refunds  Refund[]
}

model Refund {
  id           String    @id @default(uuid())
  creditNoteId String
  amount       Float
  status       String    // PENDING, PROCESSED, FAILED
  processedAt  DateTime?
  createdAt    DateTime  @default(now())
  createdBy    String?

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id])
}

/**
 * =========================
 * AUDIT
 * =========================
 */

model AuditLog {
  id        String   @id @default(uuid())
  entity    String
  entityId  String
  action    String
  actorId   String?
  metadata  Json?
  requestId String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

model Session {
  id            String   @id @default(uuid())
  token         String   @unique
  userId        String
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  lastActivityAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/**
 * =========================
 * CONTRACTS & PRICING
 * =========================
 */

model Contract {
  id          String   @id @default(uuid())
  orgId       String
  productId   String?
  name        String   // Contract name/identifier
  pricePMT    Float?   // Contract-specific price per MT (optional, can override product price)
  startDate   DateTime
  endDate     DateTime?
  active      Boolean  @default(true)
  notes       String?  // Contract terms, conditions, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org     Organization @relation(fields: [orgId], references: [id])
  product Product?     @relation(fields: [productId], references: [id])

  @@index([orgId])
  @@index([productId])
}


